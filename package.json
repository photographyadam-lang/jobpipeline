    "express": "^4.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^24.0.0",
    "msw": "^2.0.0",
    "terser": "^5.0.0"
